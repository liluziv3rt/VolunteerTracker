<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             x:Class="Volunteer_Tracker.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Button.action-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="132"/>
        </Style>

        <Style Selector="Button.action-card:pointerover">
            <Setter Property="Background" Value="#FAFBFC"/>
        </Style>

        <Style Selector="Border.stat-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="MinHeight" Value="132"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="32,24,32,24" Spacing="24">
            
<StackPanel Spacing="4">
    <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#202124">
        Добро пожаловать, <Run Text="{Binding UserFirstName}"/>!
    </TextBlock>
    <TextBlock Text="{Binding CurrentDate}" FontSize="14" Foreground="#5F6368"/>
</StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="action-card" Width="300" Command="{Binding StartVolunteerCommand}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Начать волонтёрство" FontSize="17" FontWeight="SemiBold" Foreground="#1A73E8"/>
                            <TextBlock Text="Присоединиться к новому проекту" FontSize="13.5" Foreground="#5F6368" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="56" Height="56" Background="#E8F5E9" CornerRadius="14">
                            <TextBlock Text="▶" FontSize="32" Foreground="#34A853" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <Button Classes="action-card" Width="300" Command="{Binding JoinProjectCommand}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Мои проекты" FontSize="17" FontWeight="SemiBold" Foreground="#1A73E8"/>
                            <TextBlock Text="Управление активными проектами" FontSize="13.5" Foreground="#5F6368" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="56" Height="56" Background="#E3F2FD" CornerRadius="14">
                            <TextBlock Text="📁" FontSize="32" Foreground="#4285F4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <Button Classes="action-card" Width="300" Command="{Binding NavigateToRatingCommand}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Мой рейтинг" FontSize="17" FontWeight="SemiBold" Foreground="#1A73E8"/>
                            <TextBlock Text="Посмотреть достижения" FontSize="13.5" Foreground="#5F6368" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="56" Height="56" Background="#FFF3E0" CornerRadius="14">
                            <TextBlock Text="🏆" FontSize="32" Foreground="#FB8C00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <Border Classes="stat-card" Width="300">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Волонтёрские часы" FontSize="15" Foreground="#5F6368"/>
                            <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F1}}" FontSize="42" FontWeight="Bold" Foreground="#202124"/>
                            <TextBlock Text="за семестр" FontSize="13" Foreground="#9AA0A6"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="52" Height="52" Background="#E6F4EA" CornerRadius="14" VerticalAlignment="Center">
                            <TextBlock Text="⏰" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Classes="stat-card" Width="300">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Полученные баллы" FontSize="15" Foreground="#5F6368"/>
                            <TextBlock Text="{Binding TotalPoints}" FontSize="42" FontWeight="Bold" Foreground="#1A73E8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                <TextBlock Text="+" FontSize="12" Foreground="#34A853"/>
                                <TextBlock Text="{Binding WeeklyPoints}" FontSize="12" FontWeight="SemiBold" Foreground="#34A853"/>
                                <TextBlock Text="за неделю" FontSize="12" Foreground="#5F6368"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Width="52" Height="52" Background="#E3F2FD" CornerRadius="14" VerticalAlignment="Center">
                            <TextBlock Text="💎" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Classes="stat-card" Width="300">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Завершённые проекты" FontSize="15" Foreground="#5F6368"/>
                            <TextBlock Text="{Binding CompletedProjects}" FontSize="42" FontWeight="Bold" Foreground="#202124"/>
                            <TextBlock Text="в этом семестре" FontSize="13" Foreground="#9AA0A6"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="52" Height="52" Background="#FFF3E0" CornerRadius="14" VerticalAlignment="Center">
                            <TextBlock Text="✅" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Background="White" CornerRadius="16" Padding="24,20">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🏅" FontSize="22"/>
                        <TextBlock Text="Мои достижения" FontSize="18" FontWeight="SemiBold" Foreground="#202124"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NextAchievementText}" FontSize="14" Foreground="#5F6368"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <ProgressBar Value="{Binding AchievementProgress}" Maximum="100" Height="8" CornerRadius="4">
                            <ProgressBar.Styles>
                                <Style Selector="ProgressBar">
                                    <Setter Property="Background" Value="#E8F0FE"/>
                                    <Setter Property="Foreground" Value="#1A73E8"/>
                                </Style>
                            </ProgressBar.Styles>
                        </ProgressBar>
                        <TextBlock Grid.Column="1" Text="{Binding AchievementProgress, StringFormat={}{0:F0}%}" FontSize="14" FontWeight="SemiBold" Foreground="#1A73E8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="16" Padding="24,20">
                <StackPanel Spacing="16">
                    <TextBlock Text="📋 Недавняя активность" FontSize="18" FontWeight="SemiBold" Foreground="#202124"/>
                    
                    <ItemsControl ItemsSource="{Binding RecentActivities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        
                                        <Border Width="40" Height="40" CornerRadius="12" Background="{Binding IconBackground}">
                                            <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#202124"/>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="{Binding SubtitleColor}" 
                                                           IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Text="{Binding TimeAgo}" FontSize="12" Foreground="#9AA0A6"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding PointsChange}" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="#34A853" VerticalAlignment="Center"
                                                   IsVisible="{Binding PointsChange, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>