<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             x:Class="Volunteer_Tracker.Views.RatingView"
             x:DataType="vm:RatingViewModel">

    <UserControl.Styles>
        <Style Selector="Border.leaderboard-row">
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style Selector="Border.leaderboard-row:pointerover">
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>

        <Style Selector="Border.achievement-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BoxShadow" Value="0 2 6 0 #1A000000"/>
        </Style>

        <Style Selector="Border.achievement-card.earned">
            <Setter Property="Background" Value="#E8F5E9"/>
        </Style>

        <Style Selector="Border.achievement-card.locked">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="32,24,32,24" Spacing="24">

            <!-- Заголовок -->
            <StackPanel Spacing="6">
                <TextBlock Text="Рейтинг и достижения" FontSize="28" FontWeight="SemiBold" Foreground="#202124"/>
                <TextBlock Text="Отслеживайте свой прогресс и соревнуйтесь с другими студентами" 
                           FontSize="14" Foreground="#5F6368"/>
            </StackPanel>

            <!-- ДВЕ КОЛОНКИ: таблица лидеров слева, достижения справа -->
           <Grid ColumnDefinitions="1.6*,1*" ColumnSpacing="32" VerticalAlignment="Top">

                <!-- ==================== ЛЕВАЯ КОЛОНКА - ТАБЛИЦА ЛИДЕРОВ ==================== -->
                <Border Grid.Column="0"
            Background="White"
            CornerRadius="16"
            BoxShadow="0 2 8 0 #1A000000"
            VerticalAlignment="Top">
                    <StackPanel>

                        <!-- Заголовки таблицы -->
                        <Border Padding="20,14" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="70,*,100,80" ColumnSpacing="12">
                                <TextBlock Text="Место" FontSize="13" FontWeight="SemiBold" Foreground="#5F6368"/>
                                <TextBlock Text="Студент" FontSize="13" FontWeight="SemiBold" Foreground="#5F6368"/>
                                <TextBlock Text="Баллы" FontSize="13" FontWeight="SemiBold" Foreground="#5F6368" HorizontalAlignment="Right"/>
                                <TextBlock Text="Значки" FontSize="13" FontWeight="SemiBold" Foreground="#5F6368" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Строки лидеров -->
                        <ItemsControl ItemsSource="{Binding Leaderboard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="leaderboard-row" Background="{Binding RowBackground}">
                                        <Grid ColumnDefinitions="70,*,100,80" ColumnSpacing="12">
                                            <!-- Место -->
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Rank}" FontSize="16" FontWeight="SemiBold" Foreground="{Binding RankColor}"/>
                                                <TextBlock Text="{Binding Medal}" FontSize="18"/>
                                            </StackPanel>

                                            <!-- Студент -->
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Border Width="36" Height="36" CornerRadius="18" Background="#E8F0FE">
                                                    <TextBlock Text="{Binding Initials}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#1A73E8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Spacing="1">
                                                    <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold" Foreground="#202124"/>
                                                    <TextBlock Text="{Binding GroupName}" FontSize="11" Foreground="#9AA0A6"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Баллы -->
                                            <TextBlock Text="{Binding Points}" FontSize="15" FontWeight="Bold" 
                                                       Foreground="#1A73E8" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                            <!-- Значки -->
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="🏅" FontSize="12"/>
                                                <TextBlock Text="{Binding BadgesCount}" FontSize="14" Foreground="#5F6368"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ==================== ПРАВАЯ КОЛОНКА - МОИ ДОСТИЖЕНИЯ ==================== -->
               <StackPanel Grid.Column="1"
                Spacing="16"
                VerticalAlignment="Top">

                    <!-- Заголовок счётчика -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Мои достижения" FontSize="20" FontWeight="SemiBold" Foreground="#202124"/>
                        <Border Background="#1A73E8" CornerRadius="20" Padding="12,4">
                            <TextBlock Text="{Binding AchievementsCount}" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Полученные достижения -->
                    <TextBlock Text="✅ Получено" FontSize="14" FontWeight="SemiBold" Foreground="#34A853"/>
                    <ItemsControl ItemsSource="{Binding EarnedAchievements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="achievement-card earned">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Width="40" Height="40" CornerRadius="20" Background="#E6F4EA">
                                            <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#202124"/>
                                            <TextBlock Text="{Binding Points} баллов" FontSize="11" Foreground="#34A853"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Width="22" Height="22" CornerRadius="11" Background="#34A853" VerticalAlignment="Center">
                                            <TextBlock Text="✓" Foreground="White" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Заблокированные достижения -->
                    <TextBlock Text="🔒 Заблокировано" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" Margin="0,8,0,0"/>
                    <ItemsControl ItemsSource="{Binding LockedAchievements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="achievement-card locked">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Width="40" Height="40" CornerRadius="20" Background="#F1F3F4">
                                            <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368"/>
                                            <TextBlock Text="{Binding Points} баллов" FontSize="11" Foreground="#9AA0A6"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Width="22" Height="22" CornerRadius="11" Background="#DADCE0" VerticalAlignment="Center">
                                            <TextBlock Text="🔒" Foreground="#5F6368" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>