<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             x:Class="Volunteer_Tracker.Views.RegisterView"
             x:DataType="vm:RegisterViewModel">
    
    <Design.DataContext>
        <vm:RegisterViewModel />
    </Design.DataContext>

    <UserControl.Styles>

        <!-- PRIMARY BUTTON -->
        <Style Selector="Button.primary">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Root"
                            Background="#1A73E8"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Button.primary:pressed /template/ Border#Root">
            <Setter Property="Background" Value="#0D47A1"/>
        </Style>

        <!-- LINK BUTTON -->
        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{TemplateBinding Foreground}"/>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.link:pointerover">
            <Setter Property="Foreground" Value="#1557B0"/>
        </Style>

        <!-- Стили для TextBox - БАЗОВЫЙ СТИЛЬ (ВСЕГДА) -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#202124"/>
        </Style>

        <!-- Стиль для TextBox ПРИ НАВЕДЕНИИ -->
        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
        </Style>

        <!-- Стиль для TextBox ПРИ ФОКУСЕ -->
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

    </UserControl.Styles>

    <Grid Background="#F8F9FA">
        <Border Background="#1A73E8" Opacity="0.05" />

        <ScrollViewer HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="700">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="40,35">
                <StackPanel Width="400" Spacing="16">

                    <!-- Заголовок -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Регистрация"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#202124"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Создайте аккаунт для учёта волонтёрских часов"
                                   FontSize="14"
                                   Foreground="#5F6368"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <!-- Фамилия -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Фамилия" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Введите фамилию"
                                 Text="{Binding LastName, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Имя -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Имя" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Введите имя"
                                 Text="{Binding FirstName, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Отчество -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Отчество (опционально)" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Введите отчество"
                                 Text="{Binding MiddleName, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Email" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="example@student.ru"
                                 Text="{Binding Email, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Группа -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Группа" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Например: ПИ-401"
                                 Text="{Binding GroupName, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Телефон -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Телефон" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="+7 (999) 123-45-67"
                                 Text="{Binding Phone, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Пароль -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Пароль" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Придумайте пароль"
                                 Text="{Binding Password, Mode=TwoWay}"
                                 PasswordChar="●" />
                    </StackPanel>

                    <!-- Подтверждение пароля -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Подтверждение пароля" FontSize="14" Foreground="#202124" />
                        <TextBox Watermark="Повторите пароль"
                                 Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                 PasswordChar="●" />
                    </StackPanel>

                    <!-- Ошибка -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#EA4335"
                               FontSize="13"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" />

                    <!-- Кнопка регистрации -->
                    <Button Classes="primary"
                            Content="Зарегистрироваться"
                            Command="{Binding RegisterCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="16,12" />

                    <!-- Загрузка -->
                    <ProgressBar IsVisible="{Binding IsLoading}"
                                 IsIndeterminate="True"
                                 Height="4"
                                 CornerRadius="2" />

                    <!-- Ссылка на вход -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                        <TextBlock Text="Уже есть аккаунт?" FontSize="13" Foreground="#5F6368" />
                        <Button Classes="link"
                                Content="Войти"
                                Command="{Binding NavigateToLoginCommand}"
                                FontSize="13"
                                Padding="0"
                                Cursor="Hand" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>