<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             x:Class="Volunteer_Tracker.Views.MainMenuView"
             x:DataType="vm:MainMenuViewModel"
             Width="250">

    <UserControl.Styles>
        <Style Selector="Button.menu-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        
        <Style Selector="Button.menu-item:pointerover">
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
        </Style>
        
        <!-- Стиль для выбранного пункта - используем класс .selected -->
        <Style Selector="Button.menu-item.selected">
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
        </Style>
        
        <!-- Стиль для TextBlock внутри кнопки при наведении -->
        <Style Selector="Button.menu-item:pointerover TextBlock">
            <Setter Property="Foreground" Value="#1A73E8"/>
        </Style>
        
        <!-- Стиль для TextBlock внутри выбранной кнопки -->
        <Style Selector="Button.menu-item.selected TextBlock">
            <Setter Property="Foreground" Value="#1A73E8"/>
        </Style>
    </UserControl.Styles>

    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
        
        <StackPanel Spacing="0">
            
            <!-- Логотип -->
            <Border Padding="20,25">
                <StackPanel Spacing="5">
                    <TextBlock Text="🤝" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="StudentHub"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#202124"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Меню навигации -->
            <StackPanel Margin="0,10,0,0">
                
                <Button Classes="menu-item"
                        Classes.selected="{Binding IsDashboardSelected}"
                        Command="{Binding NavigateToDashboardCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🏠" FontSize="18"/>
                        <TextBlock Text="Главная" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-item"
                        Classes.selected="{Binding IsGradebookSelected}"
                        Command="{Binding NavigateToGradebookCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="📖" FontSize="18"/>
                        <TextBlock Text="Зачётная книжка" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-item"
                        Classes.selected="{Binding IsEventsSelected}"
                        Command="{Binding NavigateToEventsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="📅" FontSize="18"/>
                        <TextBlock Text="Мероприятия" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-item"
                        Classes.selected="{Binding IsVolunteerSelected}"
                        Command="{Binding NavigateToVolunteerCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🤲" FontSize="18"/>
                        <TextBlock Text="Волонтёрство" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-item"
                        Classes.selected="{Binding IsRatingSelected}"
                        Command="{Binding NavigateToRatingCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🏆" FontSize="18"/>
                        <TextBlock Text="Рейтинг" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-item"
                        Classes.selected="{Binding IsProjectsSelected}"
                        Command="{Binding NavigateToProjectsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="📁" FontSize="18"/>
                        <TextBlock Text="Мои проекты" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
            </StackPanel>

            <!-- Профиль снизу -->
            <Border Background="White"
                    BorderBrush="#E8E8E8"
                    BorderThickness="0,1,0,0"
                    Margin="0,20,0,0"
                    Padding="16,20">
                <StackPanel Spacing="12">
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#E8F0FE"
                                Width="44"
                                Height="44"
                                CornerRadius="22">
                            <TextBlock Text="{Binding UserInitials}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#1A73E8"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding UserFullName}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#202124"/>
                            <TextBlock Text="{Binding UserRole}"
                                       FontSize="12"
                                       Foreground="#5F6368"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Background="#E8F0FE"
                            CornerRadius="10"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⭐" FontSize="14"/>
                            <TextBlock Text="{Binding UserPoints}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#1A73E8"/>
                            <TextBlock Text="баллов"
                                       FontSize="13"
                                       Foreground="#5F6368"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            Background="Transparent"
                            Foreground="#EA4335"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Padding="0,5,0,0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Foreground" Value="#D32F2F"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                </StackPanel>
            </Border>
            
        </StackPanel>
    </Border>
</UserControl>