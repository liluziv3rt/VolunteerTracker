<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             x:Class="Volunteer_Tracker.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Design.DataContext>
        <vm:LoginViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        
        <Style Selector="Button.primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Root"
                            Background="#1A73E8"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Button.primary:pressed /template/ Border#Root">
            <Setter Property="Background" Value="#0D47A1"/>
        </Style>

        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{TemplateBinding Foreground}"/>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.link:pointerover">
            <Setter Property="Foreground" Value="#1557B0"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#202124"/>
        </Style>

        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
        </Style>

        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

    </UserControl.Styles>

    <Grid Background="#F8F9FA">
        <Border Background="#1A73E8" Opacity="0.05" />

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="40,35">
                <StackPanel Spacing="24">

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="🤝" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Volunteer Tracker"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#202124"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Система учёта студенческой активности"
                                   FontSize="14"
                                   Foreground="#5F6368"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Email или телефон"
                                   FontSize="14"
                                   Foreground="#202124" />
                        <TextBox Watermark="Введите email или телефон"
                                 Text="{Binding Email, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Пароль"
                                   FontSize="14"
                                   Foreground="#202124" />
                        <TextBox Watermark="Введите пароль"
                                 Text="{Binding Password, Mode=TwoWay}"
                                 PasswordChar="●" />
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#EA4335"
                               FontSize="13"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" />

                    <Button Classes="primary"
                            Content="Войти"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="16,12" />

                    <ProgressBar IsVisible="{Binding IsLoading}"
                                 IsIndeterminate="True"
                                 Height="4"
                                 CornerRadius="2" />

                    <Button Classes="link"
                            Content="Забыли пароль?"
                            Command="{Binding ForgotPasswordCommand}"
                            HorizontalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                        <TextBlock Text="Нет аккаунта?" FontSize="13" Foreground="#5F6368" />
                        <Button Classes="link"
                                Content="Зарегистрироваться"
                                Command="{Binding NavigateToRegisterCommand}" />
                    </StackPanel>

                    <TextBlock Text="Студенты АНО | Волонтёрские часы и проекты"
                               FontSize="12"
                               Foreground="#9AA0A6"
                               HorizontalAlignment="Center" />

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>