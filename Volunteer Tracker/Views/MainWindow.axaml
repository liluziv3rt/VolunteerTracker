<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Volunteer_Tracker.Views"
        xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
        x:Class="Volunteer_Tracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="StudentHub"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="Auto,*">
        <ContentControl Grid.Column="0" Content="{Binding MenuView}"/>
        <Border Grid.Column="1" Background="#F8F9FA">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>