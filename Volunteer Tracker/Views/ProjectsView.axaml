<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volunteer_Tracker.ViewModels"
             xmlns:converters="clr-namespace:Volunteer_Tracker.Converters"
             x:Class="Volunteer_Tracker.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel"
             x:Name="Root">

    <UserControl.Resources>
        <converters:BoolToActiveTabBgConverter x:Key="ActiveBg"/>
        <converters:BoolToActiveTabFgConverter x:Key="ActiveFg"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.project-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
        </Style>

        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Border.leader-avatar">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="#E8F0FE"/>
        </Style>

        <Style Selector="Border.participant-avatar">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="32,24" Spacing="20">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Проекты" FontSize="28" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Classes="action-button"
                        Command="{Binding CreateProjectCommand}"
                        IsVisible="{Binding CanCreateProject}">
                    + Создать проект
                </Button>
            </Grid>

            <!-- Tabs -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="📋 Все проекты"
                        Command="{Binding SwitchToAvailableCommand}"
                        Background="{Binding IsAvailableSelected, Converter={StaticResource ActiveBg}}"
                        Foreground="{Binding IsAvailableSelected, Converter={StaticResource ActiveFg}}"
                        Padding="16,10" CornerRadius="8" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                
                <Button Content="👤 Мои проекты"
                        Command="{Binding SwitchToMyProjectsCommand}"
                        Background="{Binding IsMyProjectsSelected, Converter={StaticResource ActiveBg}}"
                        Foreground="{Binding IsMyProjectsSelected, Converter={StaticResource ActiveFg}}"
                        Padding="16,10" CornerRadius="8" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>

            <!-- Projects List -->
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="project-card">
                            <StackPanel Spacing="12">

                                <!-- Title + Status -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="#202124"/>
                                        <TextBlock Text="{Binding ShortDescription}" FontSize="13" Foreground="#5F6368" TextWrapping="Wrap" MaxLines="2"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="10"
                                            Padding="10,4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- Info row -->
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="20">
                                    <TextBlock Text="{Binding EndDate}" FontSize="13" Foreground="#5F6368" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="⭐" FontSize="14"/>
                                        <TextBlock Text="{Binding MaxPoints}" FontSize="13" FontWeight="SemiBold" Foreground="#1A73E8"/>
                                        <TextBlock Text="баллов" FontSize="12" Foreground="#5F6368"/>
                                    </StackPanel>

                                    <!-- Leader (кликабельный) -->
                                    <Button Grid.Column="2"
                                            Command="{Binding #Root.DataContext.OpenLeaderProfileCommand}"
                                            CommandParameter="{Binding LeaderId}"
                                            Background="Transparent"
                                            Padding="0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Classes="leader-avatar">
                                                <TextBlock Text="{Binding LeaderInitials}" FontSize="13" FontWeight="Bold"
                                                           Foreground="#1A73E8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Руководитель" FontSize="10" Foreground="#9AA0A6"/>
                                                <TextBlock Text="{Binding LeaderName}" FontSize="13" FontWeight="SemiBold" Foreground="#202124"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Progress -->
                                <StackPanel Spacing="4" IsVisible="{Binding ShowProgress}">
                                    <ProgressBar Value="{Binding ProgressPercent}" Height="6" MinHeight="6" CornerRadius="3"/>
                                    <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#5F6368"/>
                                </StackPanel>

                                <!-- Request status (если заявка отправлена) -->
                                <Border Background="{Binding RequestStatusColor}"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        IsVisible="{Binding IsPending}">
                                    <TextBlock Text="{Binding RequestStatusText}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </Border>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                           <Button Classes="action-button" Content="📤 Заявка"
                                            Command="{Binding #Root.DataContext.SendRequestCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding CanSendRequest}"/>

                                    <Button Background="#F0F0F0" Foreground="#5F6368" Content="👥 Участники"
                                            Command="{Binding #Root.DataContext.ToggleParticipantsCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="12,8" CornerRadius="8" Cursor="Hand"
                                            IsVisible="{Binding ShowParticipants}"/>

                                    <!-- Закрыть проект (только админ) -->
                                    <Button Background="#EA4335" Foreground="White" Content="Закрыть"
                                            Command="{Binding #Root.DataContext.CloseProjectCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="12,8" CornerRadius="8" Cursor="Hand"
                                            IsVisible="{Binding CanCloseProject}"/>
                                </StackPanel>

                             <!-- Participants Panel (отображается при нажатии "Участники") -->
<Border Background="#F8F9FA" CornerRadius="12" Padding="16" Margin="0,4,0,0"
        IsVisible="{Binding IsParticipantsExpanded}">
    <StackPanel Spacing="10">
        <TextBlock Text="Участники проекта" FontSize="14" FontWeight="SemiBold" Foreground="#202124"/>

        <ItemsControl ItemsSource="{Binding Participants}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            
                            <Button Command="{Binding #Root.DataContext.OpenUserProfileCommand}"
                                    CommandParameter="{Binding UserId}"
                                    Background="Transparent" Padding="0" VerticalAlignment="Center" Cursor="Hand">
                                <Border Width="32" Height="32" CornerRadius="16" Background="#F0F0F0">
                                    <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="Bold"
                                               Foreground="#5F6368" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Button>

                            <TextBlock Grid.Column="1" Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center"/>

                            <!-- Кнопки управления – поднимаемся к ProjectItem, чтобы взять CanManageParticipants -->
                           <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                        IsVisible="{Binding CanManageParticipants}">
                                
                                <Button Background="#34A853" Foreground="White" Content="✓" Padding="8,6" CornerRadius="6" FontSize="12" Cursor="Hand"
                                        Command="{Binding #Root.DataContext.AcceptUserCommand}"
                                        CommandParameter="{Binding}" IsVisible="{Binding IsPending}"/>

                                <Button Background="#FB8C00" Foreground="White" Content="✗" Padding="8,6" CornerRadius="6" FontSize="12" Cursor="Hand"
                                        Command="{Binding #Root.DataContext.RejectUserCommand}"
                                        CommandParameter="{Binding}" IsVisible="{Binding IsPending}"/>

                                <Button Background="#EA4335" Foreground="White" Content="🗑" Padding="8,6" CornerRadius="6" FontSize="12" Cursor="Hand"
                                        Command="{Binding #Root.DataContext.KickUserCommand}"
                                        CommandParameter="{Binding}" IsVisible="{Binding IsApproved}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>